# ============================================================
#  CBE LMS – Environment Configuration EXAMPLE
#  -------------------------------------------------------
#  1. Copy this file:  cp .env.example .env
#  2. Fill in ALL values marked with <...>
#  3. NEVER commit .env to version control
#  This file IS safe to commit (no real secrets here).
# ============================================================

# ----- Application -----
APP_NAME="CBE Learning Management System"
APP_ENV=local                   # local | staging | production
APP_DEBUG=true                  # true | false
APP_URL=http://localhost
APP_BASE_PATH=/CBE_LMS          # Sub-directory path (no trailing slash)
APP_TIMEZONE=Africa/Nairobi
APP_KEY=<generate-a-32-char-random-string>   # Used for CSRF / session signing

# ----- Session -----
SESSION_LIFETIME=120            # Session lifetime in minutes

# ----- Database -----
DB_HOST=localhost
DB_NAME=cbelms
DB_USERNAME=root
DB_PASSWORD=<your-db-password>

# ----- Mail (SMTP) -----
# For Gmail: enable 2FA and generate an App Password at
# https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls             # tls | ssl
MAIL_USERNAME=<your_email@gmail.com>
MAIL_PASSWORD=<your-gmail-app-password>   # NOT your Gmail login password
MAIL_FROM_ADDRESS=<your_email@gmail.com>
MAIL_FROM_NAME="CBE LMS"
